---
import { SITE } from '../../utils/constants';
---

<header class="border-b border-stone-200 bg-white">
  <div class="mx-auto flex max-w-3xl items-center justify-between gap-4 px-6 py-4">
    <a href="/" class="flex items-center gap-2 font-bold text-stone-900">
      <span
        class="flex size-8 items-center justify-center rounded-lg bg-brand-600 text-xs font-bold text-white"
        aria-hidden="true"
      >
        OY
      </span>
      {SITE.name}
    </a>
    <a href="/" class="text-sm font-medium text-stone-600 transition-colors hover:text-stone-900">
      ← Volver al inicio
    </a>
  </div>
</header>
