---
import SectionHeading from '../ui/SectionHeading.astro';

const faqs = [
  {
    question: '¿Mis clientes necesitan instalar una app?',
    answer:
      'No. Tus clientes siguen pidiendo por WhatsApp como siempre. OrdenYa es para ti y tu equipo: organiza los pedidos que ya recibes en el chat.',
  },
  {
    question: '¿Funciona con mi número de WhatsApp actual?',
    answer:
      'Sí. Puedes conectar el WhatsApp Business de tu restaurante para que los pedidos se centralicen en el panel de OrdenYa.',
  },
  {
    question: '¿Puedo usar OrdenYa si tengo más de un empleado?',
    answer:
      'Claro. Los planes Profesional y Empresa permiten varios usuarios con acceso al mismo negocio para que cocina, caja y administración trabajen en sincronía.',
  },
  {
    question: '¿Qué pasa con mis datos si cancelo?',
    answer:
      'Tus datos te pertenecen. Puedes exportar reportes de ventas y pedidos antes de cancelar. No hay penalización por cancelar en cualquier momento.',
  },
  {
    question: '¿Incluye control de inventario?',
    answer:
      'Sí, desde el plan Profesional. Puedes registrar insumos, dar de baja por venta y recibir alertas cuando un producto esté por agotarse.',
  },
  {
    question: '¿Ofrecen capacitación?',
    answer:
      'Sí. Incluimos onboarding guiado en todos los planes. El plan Empresa incluye capacitación presencial o en videollamada para todo tu equipo.',
  },
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer,
    },
  })),
};
---

<section id="faq" class="py-24">
  <div class="mx-auto max-w-3xl px-6">
    <SectionHeading eyebrow="FAQ" title="Preguntas frecuentes" />

    <div class="mt-12 divide-y divide-stone-200 overflow-hidden rounded-2xl border border-stone-200 bg-white shadow-sm">
      {
        faqs.map((faq, i) => (
          <details class="group" open={i === 0}>
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-6 py-5 font-semibold text-stone-900 transition-colors hover:bg-stone-50 marker:content-none">
              <span class="pr-4">{faq.question}</span>
              <span class="flex size-8 shrink-0 items-center justify-center rounded-lg border border-stone-200 bg-stone-50 text-stone-500 transition-all group-open:rotate-180 group-open:border-brand-200 group-open:bg-brand-50 group-open:text-brand-700">
                <svg class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </span>
            </summary>
            <p class="border-t border-stone-100 bg-stone-50/50 px-6 py-4 text-sm leading-relaxed text-stone-600">
              {faq.answer}
            </p>
          </details>
        ))
      }
    </div>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
</section>
