---
import Button from '../ui/Button.astro';
import WhatsAppButton from '../ui/WhatsAppButton.astro';

const stats = [
  { value: '3x', label: 'más rápido atender pedidos' },
  { value: '0', label: 'pedidos perdidos en el chat' },
  { value: '1', label: 'panel para todo el negocio' },
];

const perks = ['14 días gratis', 'Sin tarjeta', 'Soporte en español'];
---

<section class="mesh-bg relative overflow-hidden">
  <div class="pointer-events-none absolute inset-0 grid-dots opacity-40" aria-hidden="true"></div>
  <div
    class="pointer-events-none absolute -right-32 top-20 size-96 rounded-full bg-brand-200/40 blur-3xl"
    aria-hidden="true"
  ></div>
  <div
    class="pointer-events-none absolute -left-20 bottom-0 size-72 rounded-full bg-accent-400/20 blur-3xl"
    aria-hidden="true"
  ></div>

  <div class="relative mx-auto grid max-w-6xl gap-14 px-6 py-20 md:grid-cols-2 md:items-center md:py-28">
    <div>
      <span class="section-badge">Para restaurantes y negocios de comida</span>

      <h1 class="mt-6 max-w-xl text-4xl font-extrabold tracking-tight text-stone-900 md:text-5xl lg:text-[3.25rem] lg:leading-[1.1]">
        Controla tus pedidos de <span class="gradient-text">WhatsApp</span> sin perder ventas
      </h1>

      <p class="mt-6 max-w-lg text-lg leading-relaxed text-stone-600">
        OrdenYa centraliza pedidos, ventas, inventario y egresos en una sola plataforma. Deja de buscar mensajes en el
        chat y empieza a operar con orden.
      </p>

      <div class="mt-8 flex flex-wrap items-center gap-3">
        <WhatsAppButton label="Solicitar demo gratis" class="btn-pulse" />
        <Button href="#como-funciona" variant="secondary">
          <svg class="mr-1.5 size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
          </svg>
          Ver cómo funciona
        </Button>
      </div>

      <ul class="mt-6 flex flex-wrap gap-2">
        {
          perks.map((perk) => (
            <li class="inline-flex items-center gap-1.5 rounded-full border border-stone-200 bg-white/80 px-3 py-1 text-xs font-medium text-stone-600 backdrop-blur-sm">
              <svg class="size-3.5 text-brand-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
              </svg>
              {perk}
            </li>
          ))
        }
      </ul>

      <dl class="mt-10 grid grid-cols-3 gap-4 rounded-2xl border border-stone-200/80 bg-white/60 p-5 backdrop-blur-sm">
        {
          stats.map((stat) => (
            <div class="text-center md:text-left">
              <dt class="sr-only">{stat.label}</dt>
              <dd class="text-2xl font-extrabold text-stone-900 md:text-3xl">{stat.value}</dd>
              <dd class="mt-1 text-xs leading-snug text-stone-500">{stat.label}</dd>
            </div>
          ))
        }
      </dl>
    </div>

    <div class="relative lg:pl-4">
      <div class="animate-float rounded-2xl border border-stone-200/80 bg-white/90 p-2 shadow-2xl shadow-stone-900/10 ring-1 ring-stone-900/5 backdrop-blur-sm">
        <div class="rounded-xl bg-gradient-to-r from-stone-900 to-stone-800 px-4 py-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2">
              <span class="size-2.5 rounded-full bg-red-400" aria-hidden="true"></span>
              <span class="size-2.5 rounded-full bg-amber-400" aria-hidden="true"></span>
              <span class="size-2.5 rounded-full bg-green-400" aria-hidden="true"></span>
            </div>
            <span class="text-xs font-medium text-stone-400">panel.ordenya.app</span>
          </div>
        </div>

        <div class="space-y-3 p-4">
          <div class="flex items-center justify-between">
            <p class="text-sm font-bold text-stone-900">Pedidos de hoy</p>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-100 px-2.5 py-0.5 text-xs font-semibold text-brand-800">
              <span class="size-1.5 animate-pulse rounded-full bg-brand-600" aria-hidden="true"></span>
              12 activos
            </span>
          </div>

          <div class="space-y-2">
            <article class="rounded-xl border border-brand-200 bg-gradient-to-br from-brand-50 to-white p-4 shadow-sm">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <span class="inline-flex items-center gap-1 rounded-md bg-brand-600 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wide text-white">
                    <svg class="size-3" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.435 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
                    </svg>
                    Nuevo
                  </span>
                  <h2 class="mt-2 font-bold text-stone-900">Combo familiar + refresco</h2>
                  <p class="mt-1 text-sm text-stone-600">Cliente: Ana García</p>
                </div>
                <span class="shrink-0 rounded-lg bg-white px-2.5 py-1 text-sm font-bold text-stone-900 shadow-sm">$289</span>
              </div>
              <div class="mt-3 flex gap-2">
                <span class="rounded-lg bg-brand-600 px-3 py-1.5 text-xs font-semibold text-white shadow-sm">Confirmar</span>
                <span class="rounded-lg border border-stone-200 bg-white px-3 py-1.5 text-xs font-medium text-stone-600">Ver chat</span>
              </div>
            </article>

            <article class="rounded-xl border border-stone-200 bg-stone-50/80 p-4">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <p class="text-xs font-semibold text-amber-600">En preparación</p>
                  <h2 class="mt-1 font-bold text-stone-900">2 burgers + papas</h2>
                  <p class="mt-1 text-sm text-stone-600">Cliente: Memo Torres</p>
                </div>
                <span class="shrink-0 rounded-lg bg-white px-2.5 py-1 text-sm font-bold text-stone-700">$195</span>
              </div>
            </article>

            <article class="rounded-xl border border-stone-100 bg-white p-4 opacity-70">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <p class="text-xs font-semibold text-brand-600">Entregado ✓</p>
                  <h2 class="mt-1 font-semibold text-stone-800">Ensalada césar</h2>
                  <p class="mt-1 text-sm text-stone-500">Cliente: Luis R.</p>
                </div>
                <span class="text-sm font-semibold text-stone-400">$89</span>
              </div>
            </article>
          </div>
        </div>
      </div>

      <div
        class="absolute -bottom-5 -left-5 rounded-2xl border border-stone-200 bg-white px-5 py-4 shadow-xl shadow-stone-900/10"
        aria-hidden="true"
      >
        <p class="text-xs font-medium text-stone-500">Ventas del día</p>
        <p class="text-2xl font-extrabold text-brand-700">$4,280</p>
        <p class="mt-0.5 text-xs text-green-600">↑ 18% vs ayer</p>
      </div>

      <div
        class="absolute -right-3 top-8 rounded-xl border border-stone-200 bg-white px-3 py-2 shadow-lg"
        aria-hidden="true"
      >
        <div class="flex items-center gap-2">
          <div class="flex -space-x-2">
            <span class="flex size-7 items-center justify-center rounded-full border-2 border-white bg-brand-100 text-[10px] font-bold text-brand-700">AG</span>
            <span class="flex size-7 items-center justify-center rounded-full border-2 border-white bg-amber-100 text-[10px] font-bold text-amber-700">MT</span>
            <span class="flex size-7 items-center justify-center rounded-full border-2 border-white bg-stone-200 text-[10px] font-bold text-stone-600">+9</span>
          </div>
          <span class="text-xs font-medium text-stone-600">12 pedidos</span>
        </div>
      </div>
    </div>
  </div>
</section>
