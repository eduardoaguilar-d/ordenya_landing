---
import SectionHeading from '../ui/SectionHeading.astro';

const features = [
  {
    title: 'Pedidos desde WhatsApp',
    description:
      'Recibe y organiza pedidos que llegan por WhatsApp en un panel claro con estados: nuevo, confirmado, en preparación y entregado.',
    icon: 'M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z',
    accent: 'bg-emerald-500',
  },
  {
    title: 'Control de ventas',
    description:
      'Visualiza ventas del día, semana y mes. Identifica tus productos más vendidos y toma mejores decisiones.',
    icon: 'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
    accent: 'bg-blue-500',
  },
  {
    title: 'Inventario en tiempo real',
    description:
      'Lleva control de insumos y productos. Recibe alertas cuando algo se está acabando antes de que afecte tus ventas.',
    icon: 'M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4',
    accent: 'bg-violet-500',
  },
  {
    title: 'Egresos y gastos',
    description:
      'Registra compras de insumos, nómina y gastos operativos para conocer la utilidad real de tu negocio.',
    icon: 'M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z',
    accent: 'bg-amber-500',
  },
  {
    title: 'Menú digital',
    description:
      'Comparte tu menú actualizado con precios y disponibilidad. Tus clientes piden con claridad desde el primer mensaje.',
    icon: 'M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2',
    accent: 'bg-rose-500',
  },
  {
    title: 'Multi-usuario',
    description:
      'Tu equipo puede operar el mismo negocio con roles definidos: cocina, caja, administración y más.',
    icon: 'M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z',
    accent: 'bg-cyan-500',
  },
];
---

<section id="funciones" class="py-24">
  <div class="mx-auto max-w-6xl px-6">
    <SectionHeading
      eyebrow="Funciones"
      title="Todo lo que tu restaurante necesita en un solo lugar"
      description="OrdenYa conecta WhatsApp con la operación diaria de tu negocio para que vendas más y trabajes con menos estrés."
    />

    <ul class="mt-16 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature) => (
          <li class="card-hover group relative overflow-hidden rounded-2xl border border-stone-200 bg-white p-6">
            <div
              class:list={['absolute -right-6 -top-6 size-24 rounded-full opacity-10 blur-2xl', feature.accent]}
              aria-hidden="true"
            />
            <div
              class:list={[
                'relative flex size-12 items-center justify-center rounded-xl text-white shadow-lg transition-transform group-hover:scale-110',
                feature.accent,
              ]}
            >
              <svg class="size-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d={feature.icon} />
              </svg>
            </div>
            <h3 class="relative mt-5 text-lg font-bold text-stone-900">{feature.title}</h3>
            <p class="relative mt-2 text-sm leading-relaxed text-stone-600">{feature.description}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
