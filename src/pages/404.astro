---
import BaseLayout from '../layouts/BaseLayout.astro';
import Button from '../components/ui/Button.astro';
---

<BaseLayout title="Página no encontrada | OrdenYa" description="La página que buscas no existe.">
  <main class="mx-auto flex min-h-screen max-w-2xl flex-col items-center justify-center px-6 py-24 text-center">
    <p class="text-6xl font-bold text-brand-600">404</p>
    <h1 class="mt-4 text-3xl font-bold text-stone-900">Página no encontrada</h1>
    <p class="mt-4 text-stone-600">La página que buscas no existe o fue movida.</p>
    <Button href="/" variant="primary" class="mt-8">
      Volver al inicio
    </Button>
  </main>
</BaseLayout>
